{
  "name": "zosma-anti-encryption",
  "version": "2.0.0",
  "description": "Encryption-level narratives, taxonomy break audits, and live toy-RSA Shor on IBM Quantum",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "demo": "tsx src/index.ts --modulus 15 --message ZOSMA --shots 1024 --max-attempts 2",
    "factor": "tsx src/factor.ts",
    "audit": "tsx src/audit-cli.ts",
    "audit:insecure": "tsx src/audit-cli.ts audit --profile insecure",
    "audit:hardened": "tsx src/audit-cli.ts audit --profile hardened",
    "high-asset": "tsx src/high-asset-cli.ts",
    "high-asset:test": "tsx src/high-asset-cli.ts self-test",
    "high-asset:broken": "tsx src/high-asset-cli.ts audit --profile broken",
    "high-asset:hardened": "tsx src/high-asset-cli.ts audit --profile hardened",
    "blind": "tsx src/blind-cli.ts",
    "blind:live": "tsx src/blind-cli.ts live",
    "gcm-bypass": "tsx src/gcm-bypass-cli.ts",
    "gcm-beyond": "tsx src/gcm-beyond-cli.ts",
    "quantum:install": "python -m pip install -r quantum/requirements.txt",
    "quantum:factor": "python quantum/shor_live.py"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
