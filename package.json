{
  "name": "zosma-anti-encryption",
  "version": "2.0.0",
  "description": "Live RSA break: real RSA + Shor order-finding on IBM Quantum hardware",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "demo": "tsx src/index.ts --modulus 15 --message ZOSMA --shots 1024 --max-attempts 2",
    "factor": "tsx src/factor.ts",
    "quantum:install": "python -m pip install -r quantum/requirements.txt",
    "quantum:factor": "python quantum/shor_live.py"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
